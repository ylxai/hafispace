    "@tanstack/react-query": "^5.59.0",
    "@upstash/redis": "^1.36.4",
    "ably": "^2.18.0",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.0",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.460.0",
    "next": "^15.5.14",
    "next-auth": "4.24.13",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.3",
