{
  "name": "my-platform",
  "version": "0.1.0",
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
