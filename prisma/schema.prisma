generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id                      String             @id @default(uuid()) @db.Uuid
  username                String             @unique
  email                   String             @unique
  password                String
  namaStudio              String?            @map("nama_studio")
  logoUrl                 String?            @map("logo_url")
  phone                   String?
  googleRefreshToken      String?            @map("google_refresh_token")
  googleFolderId          String?            @map("google_folder_id")
  status                  VendorStatus       @default(ACTIVE)
  subscriptionType        SubscriptionType   @default(VIEWSPACE) @map("subscription_type")
  subscriptionExpired     DateTime?          @map("subscription_expired")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  r2AccessKeyId           String?            @map("r2_access_key_id")
  r2SecretAccessKey       String?            @map("r2_secret_access_key")
  r2BucketName            String?            @map("r2_bucket_name")
  r2Endpoint              String?            @map("r2_endpoint")
  cloudinaryCloudName     String?            @map("cloudinary_cloud_name")
  cloudinaryApiKey        String?            @map("cloudinary_api_key")
  cloudinaryApiSecret     String?            @map("cloudinary_api_secret")
  enableViesusEnhancement Boolean            @default(false) @map("enable_viesus_enhancement")
  dpPercentage            Int                @default(30) @map("dp_percentage")
  rekeningPembayaran      String?            @map("rekening_pembayaran")
  syaratKetentuan         String?            @map("syarat_ketentuan")
  themeColor              String             @default("#0f172a") @map("theme_color")
  successMessage          String?            @map("success_message")
  bookingFormActive       Boolean            @default(true) @map("booking_form_active")
  waAdmin                 String?            @map("wa_admin")
  notifEmail              Boolean            @default(true) @map("notif_email")
  notifGalleryDelivered   Boolean            @default(true) @map("notif_gallery_delivered")
  notifNewBooking         Boolean            @default(true) @map("notif_new_booking")
  activityLogs            ActivityLog[]
  bookings                Booking[]
  clients                 Client[]
  customFields            CustomField[]
  galleries               Gallery[]
  notifications           Notification[]
  packages                Package[]
  payments                Payment[]
  cloudinaryAccounts      VendorCloudinary[]

  @@map("vendors")
}

model VendorCloudinary {
  id          String   @id @default(uuid()) @db.Uuid
  vendorId    String   @map("vendor_id") @db.Uuid
  name        String
  cloudName   String   @map("cloud_name")
  apiKey      String   @map("api_key")
  apiSecret   String   @map("api_secret")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  storageUsed BigInt   @default(0) @map("storage_used")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_cloudinary_accounts")
}

model Package {
  id           String          @id @default(uuid()) @db.Uuid
  vendorId     String          @map("vendor_id") @db.Uuid
  namaPaket    String          @map("nama_paket")
  harga        Decimal         @default(0) @db.Decimal(15, 0)
  deskripsi    String?
  fitur        Json?
  isCustomable Boolean         @default(false) @map("is_customable")
  urutan       Int             @default(0)
  status       String          @default("active")
  createdAt    DateTime        @default(now()) @map("created_at")
  kategori     PackageCategory @default(LAINNYA)
  kuotaEdit    Int?            @map("kuota_edit")
  includeCetak Json?           @map("include_cetak")
  maxSelection Int             @default(40) @map("max_selection")
  bookings     Booking[]
  vendor       Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([kategori])
  @@map("packages")
}

model Client {
  id           String    @id @default(uuid()) @db.Uuid
  vendorId     String    @map("vendor_id") @db.Uuid
  name         String
  email        String?
  phone        String?
  instagram    String?
  customFields Json?     @map("custom_fields")
  totalBooking Int       @default(0) @map("total_booking")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  bookings     Booking[]
  vendor       Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([name])
  @@index([email])
  @@index([phone])
  @@map("clients")
}

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  vendorId     String        @map("vendor_id") @db.Uuid
  clientId     String?       @map("client_id") @db.Uuid
  kodeBooking  String        @unique @map("kode_booking")
  namaClient   String        @map("nama_client")
  hpClient     String        @map("hp_client")
  emailClient  String?       @map("email_client")
  paketId      String?       @map("paket_id") @db.Uuid
  paketCustom  String?       @map("paket_custom")
  hargaPaket   Decimal?      @map("harga_paket") @db.Decimal(15, 0)
  tanggalSesi  DateTime      @map("tanggal_sesi")
  lokasiSesi   String?       @map("lokasi_sesi")
  status       BookingStatus @default(PENDING)
  dpAmount     Decimal?      @map("dp_amount") @db.Decimal(15, 0)
  dpStatus     DpStatus      @default(UNPAID) @map("dp_status")
  invoiceUrl   String?       @map("invoice_url")
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  maxSelection Int           @default(40) @map("max_selection")
  client       Client?       @relation(fields: [clientId], references: [id])
  paket        Package?      @relation(fields: [paketId], references: [id])
  vendor       Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  galleries    Gallery[]
  payments     Payment[]

  @@index([vendorId])
  @@index([vendorId, status])
  @@index([vendorId, tanggalSesi])
  @@index([clientId])
  @@index([paketId])
  @@index([tanggalSesi])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model Payment {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId  String      @map("booking_id") @db.Uuid
  vendorId   String      @map("vendor_id") @db.Uuid
  jumlah     Decimal     @db.Decimal(15, 0)
  tipe       PaymentType @default(DP)
  keterangan String?
  buktiBayar String?     @map("bukti_bayar")
  createdAt  DateTime    @default(now()) @map("created_at")
  booking    Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vendor     Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bookingId])
  @@index([vendorId])
  @@index([createdAt])
  @@map("payments")
}

model Gallery {
  id                 String           @id @default(uuid()) @db.Uuid
  vendorId           String           @map("vendor_id") @db.Uuid
  bookingId          String?          @map("booking_id") @db.Uuid
  namaProject        String           @map("nama_project")
  clientToken        String           @unique @map("client_token")
  viewCount          Int              @default(0) @map("view_count")
  status             GalleryStatus    @default(DRAFT)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  cloudinaryFolderId String?          @map("cloudinary_folder_id")
  storageProvider    String           @default("Cloudinary") @map("storage_provider")
  tokenExpiresAt     DateTime?        @map("token_expires_at")
  booking            Booking?         @relation(fields: [bookingId], references: [id])
  vendor             Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  settings           GallerySetting?
  selections         PhotoSelection[]
  photos             Photo[]

  @@index([vendorId])
  @@index([bookingId])
  @@index([clientToken])
  @@index([status])
  @@index([createdAt])
  @@map("galleries")
}

model GallerySetting {
  id               String    @id @default(uuid()) @db.Uuid
  galleryId        String    @unique @map("gallery_id") @db.Uuid
  enableDownload   Boolean   @default(true) @map("enable_download")
  downloadExpired  DateTime? @map("download_expired")
  enablePrint      Boolean   @default(false) @map("enable_print")
  printSpecs       Json?     @map("print_specs")
  watermarkEnabled Boolean   @default(false) @map("watermark_enabled")
  watermarkText    String?   @map("watermark_text")
  bannerClientName String?   @map("banner_client_name")
  bannerEventDate  DateTime? @map("banner_event_date")
  bannerMessage    String?   @map("banner_message")
  welcomeMessage   String?   @map("welcome_message")
  thankYouMessage  String?   @map("thank_you_message")
  gallery          Gallery   @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@map("gallery_settings")
}

model Photo {
  id           String   @id @default(uuid()) @db.Uuid
  galleryId    String   @map("gallery_id") @db.Uuid
  storageKey   String   @map("storage_key")
  filename     String
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  width        Int?
  height       Int?
  size         Int?
  mimeType     String?  @default("image/jpeg") @map("mime_type")
  urutan       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  gallery      Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@unique([galleryId, storageKey])
  @@index([galleryId, urutan])
  @@map("photos")
}

model PhotoSelection {
  id            String        @id @default(uuid()) @db.Uuid
  galleryId     String        @map("gallery_id") @db.Uuid
  fileId        String        @map("file_id")
  filename      String
  filePath      String?       @map("file_path")
  selectionType SelectionType @default(EDIT) @map("selection_type")
  printSize     String?       @map("print_size")
  selectedAt    DateTime      @default(now()) @map("selected_at")
  lockedAt      DateTime?     @map("locked_at")
  isLocked      Boolean       @default(false) @map("is_locked")
  gallery       Gallery       @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@unique([galleryId, fileId])
  @@index([galleryId, isLocked])
  @@index([galleryId, selectedAt])
  @@index([fileId])
  @@index([selectionType])
  @@index([selectedAt])
  @@index([galleryId])
  @@map("photo_selections")
}

model CustomField {
  id         String    @id @default(uuid()) @db.Uuid
  vendorId   String    @map("vendor_id") @db.Uuid
  namaField  String    @map("nama_field")
  tipe       FieldType @default(TEXT)
  options    Json?
  wajib      Boolean   @default(false)
  urutan     Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")
  label      String    @default("")
  isRequired Boolean   @default(false) @map("is_required")
  isActive   Boolean   @default(true) @map("is_active")
  vendor     Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("custom_fields")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  vendorId  String           @map("vendor_id") @db.Uuid
  type      NotificationType
  title     String
  message   String?
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  vendor    Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String?  @map("vendor_id") @db.Uuid
  galleryId String?  @map("gallery_id") @db.Uuid
  action    String
  details   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  vendor    Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([createdAt])
  @@map("activity_logs")
}

enum UserRole {
  ADMIN
  CLIENT
  GUEST
}

enum VendorStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionType {
  VIEWSPACE
  PICKSPACE
  BIZSPACE
  OMNISPACE
}

enum PackageCategory {
  PREWED
  WEDDING
  PERSONAL
  EVENT
  LAINNYA
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum DpStatus {
  UNPAID
  PAID
  PARTIAL
}

enum PaymentType {
  DP
  PELUNASAN
  LAINNYA
}

enum GalleryStatus {
  DRAFT
  IN_REVIEW
  DELIVERED
}

enum SelectionType {
  EDIT
  PRINT
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  TEXTAREA
}

enum NotificationType {
  BOOKING_NEW
  BOOKING_CONFIRMED
  DP_RECEIVED
  SELECTION_DONE
  PRINT_LOCKED
  SELECTION_SUBMITTED
}
